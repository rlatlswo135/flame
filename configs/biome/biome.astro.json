{
  "extends": "//",
  "overrides": [
    {
      "includes": ["**/*.svelte", "**/*.astro", "**/*.vue"],
      "javascript": {
        "formatter": {
          "quoteStyle": "single",
          "indentStyle": "space",
          "indentWidth": 2,
          "lineWidth": 100
        }
      },
      "linter": {
        "rules": {
          "style": {
            "useConst": "off",
            "useImportType": "off"
          },
          "correctness": {
            "noUnusedVariables": "off",
            "noUnusedImports": "off"
          }
        }
      }
    }
  ]
}
