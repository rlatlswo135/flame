---
import { DialogSection } from '../../../../../components/demos/dialog-demo';
import { PropsTable } from '../../../../../components/props-table';
import DocsLayout from '../../../../../layouts/DocsLayout.astro';
import { highlight } from '../../../../../lib/highlight';

export function getStaticPaths() {
  return [{ params: { locale: 'ko' } }, { params: { locale: 'en' } }];
}

const { locale } = Astro.params;
const messages = (await import(`../../../../../../messages/${locale}.json`)).default;
const t = messages.components.dialog;
const tc = messages.components;

const demoCode = `import { Dialog } from '@flame/ui';

function DialogExample() {
  return (
    <Dialog closeOutside>
      <Dialog.Trigger>
        <button>Open Dialog</button>
      </Dialog.Trigger>
      <Dialog.Content>
        <h2>Welcome to Flame</h2>
        <Dialog.Closer>
          <button>Close</button>
        </Dialog.Closer>
      </Dialog.Content>
    </Dialog>
  );
}`;

const codeHtml = await highlight(demoCode);

const dialogProps = [
  { name: 'children', type: 'ReactNode', description: t.props.children },
  {
    name: 'closeOutside',
    type: 'boolean',
    defaultValue: 'false',
    description: t.props.closeOutside,
  },
  { name: 'keepMounted', type: 'boolean', defaultValue: 'false', description: t.props.keepMounted },
];
const triggerProps = [
  {
    name: 'children',
    type: 'ReactElement | ((props: { open }) => ReactNode)',
    description: t.props.triggerChildren,
  },
];
const contentProps = [
  {
    name: '...props',
    type: 'ComponentPropsWithoutRef<"dialog">',
    description: t.props.contentProps,
  },
];
const closerProps = [
  {
    name: 'children',
    type: 'ReactElement | ((props: { close }) => ReactNode)',
    description: t.props.closerChildren,
  },
];
---

<DocsLayout locale={locale} title={`${t.title} — Flame`}>
  <div>
    <h1 class="text-3xl font-bold mb-3">{t.title}</h1>
    <p class="text-flame-text-secondary mb-8 text-lg leading-relaxed">{t.description}</p>

    <section class="mb-12">
      <h2 class="text-xl font-semibold mb-4">{tc.demo}</h2>
      <DialogSection client:load t={t.demo} code={demoCode} codeHtml={codeHtml} />
    </section>

    <section>
      <h2 class="text-xl font-semibold mb-6">{tc.apiReference}</h2>
      <PropsTable title="Dialog" props={dialogProps} />
      <PropsTable title="Dialog.Trigger" props={triggerProps} />
      <PropsTable title="Dialog.Content" props={contentProps} />
      <PropsTable title="Dialog.Closer" props={closerProps} />
    </section>
  </div>
</DocsLayout>
