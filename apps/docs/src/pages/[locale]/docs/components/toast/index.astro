---
import { ToastSection } from '../../../../../components/demos/toast-demo';
import { PropsTable } from '../../../../../components/props-table';
import DocsLayout from '../../../../../layouts/DocsLayout.astro';
import { highlight } from '../../../../../lib/highlight';

export function getStaticPaths() {
  return [{ params: { locale: 'ko' } }, { params: { locale: 'en' } }];
}

const { locale } = Astro.params;
const messages = (await import(`../../../../../../messages/${locale}.json`)).default;
const t = messages.components.toast;
const tc = messages.components;

const demoCode = `import { Toast, Toaster, toast } from 'flame-ui';

function App() {
  return (
    <>
      <Toaster placement="bottom-right" />
      <button
        onClick={() =>
          toast(
            <Toast>
              <Toast.Title>Saved</Toast.Title>
              <Toast.Description>Changes saved.</Toast.Description>
            </Toast>,
          )
        }
      >
        Show Toast
      </button>
    </>
  );
}`;

const codeHtml = await highlight(demoCode);

const toasterProps = [
  {
    name: 'placement',
    type: '"top-left" | "top-right" | "bottom-left" | "bottom-right"',
    defaultValue: '"bottom-left"',
    description: t.props.placement,
  },
  {
    name: 'animation',
    type: 'ToastAnimation | false',
    description: t.props.animation,
  },
  {
    name: '...props',
    type: 'ComponentPropsWithRef<"section">',
    description: t.props.toasterProps,
  },
];
const toastProps = [
  {
    name: '...props',
    type: 'ComponentPropsWithRef<"div">',
    description: t.props.toastProps,
  },
];
const titleProps = [
  {
    name: '...props',
    type: 'ComponentPropsWithRef<"div">',
    description: t.props.titleProps,
  },
];
const descriptionProps = [
  {
    name: '...props',
    type: 'ComponentPropsWithRef<"div">',
    description: t.props.descriptionProps,
  },
];
const toastFnProps = [
  { name: 'content', type: 'ReactNode', description: t.props.fnContent },
  {
    name: 'options.timeout',
    type: 'number',
    defaultValue: '3000',
    description: t.props.fnTimeout,
  },
];
---

<DocsLayout locale={locale} title={`${t.title} — Flame`}>
  <div>
    <h1 class="text-3xl font-bold mb-3">{t.title}</h1>
    <p class="text-flame-text-secondary mb-8 text-lg leading-relaxed">{t.description}</p>

    <section class="mb-12">
      <h2 class="text-xl font-semibold mb-4">{tc.demo}</h2>
      <ToastSection client:load t={t.demo} code={demoCode} codeHtml={codeHtml} />
    </section>

    <section>
      <h2 class="text-xl font-semibold mb-6">{tc.apiReference}</h2>
      <PropsTable title="Toaster" props={toasterProps} />
      <PropsTable title="Toast" props={toastProps} />
      <PropsTable title="Toast.Title" props={titleProps} />
      <PropsTable title="Toast.Description" props={descriptionProps} />
      <PropsTable title="toast(content, options?)" props={toastFnProps} />
    </section>
  </div>
</DocsLayout>
