---
import { PopoverSection } from '../../../../../components/demos/popover-demo';
import { PropsTable } from '../../../../../components/props-table';
import DocsLayout from '../../../../../layouts/DocsLayout.astro';
import { highlight } from '../../../../../lib/highlight';

export function getStaticPaths() {
  return [{ params: { locale: 'ko' } }, { params: { locale: 'en' } }];
}

const { locale } = Astro.params;
const messages = (await import(`../../../../../../messages/${locale}.json`)).default;
const t = messages.components.popover;
const tc = messages.components;

const demoCode = `import { Popover } from '@flame/ui';

function PopoverExample() {
  return (
    <Popover transition>
      <Popover.Trigger>
        <button>Open Popover</button>
      </Popover.Trigger>
      <Popover.Content>
        <h3>Popover Title</h3>
        <p>This is a popover with Floating UI positioning.</p>
      </Popover.Content>
    </Popover>
  );
}`;

const codeHtml = await highlight(demoCode);

const popoverProps = [
  { name: 'children', type: 'ReactNode', description: t.props.children },
  {
    name: 'transition',
    type: 'boolean | UseTransitionStylesProps',
    defaultValue: 'false',
    description: t.props.transition,
  },
  { name: 'dismiss', type: 'UseDismissProps', description: t.props.dismiss },
  { name: 'onOpen', type: '() => void', description: t.props.onOpen },
  { name: 'onClose', type: '() => void', description: t.props.onClose },
  { name: 'open', type: 'boolean', description: t.props.open },
  {
    name: 'onOpenChange',
    type: '(open: boolean) => void',
    description: t.props.onOpenChange,
  },
  { name: 'options', type: 'UseFloatingOptions', description: t.props.options },
];
const triggerProps = [
  {
    name: 'children',
    type: 'ReactElement',
    description: t.props.triggerChildren,
  },
];
const contentProps = [
  {
    name: 'children',
    type: 'ReactNode | ((props: { floating, interactions }) => ReactNode)',
    description: t.props.contentChildren,
  },
  {
    name: 'portal',
    type: 'boolean | FloatingPortalProps',
    defaultValue: 'false',
    description: t.props.portal,
  },
  {
    name: '...props',
    type: 'ComponentPropsWithoutRef<"section">',
    description: t.props.contentProps,
  },
];
---

<DocsLayout locale={locale} title={`${t.title} — Flame`}>
  <div>
    <h1 class="text-3xl font-bold mb-3">{t.title}</h1>
    <p class="text-flame-text-secondary mb-8 text-lg leading-relaxed">{t.description}</p>

    <section class="mb-12">
      <h2 class="text-xl font-semibold mb-4">{tc.demo}</h2>
      <PopoverSection client:load t={t.demo} code={demoCode} codeHtml={codeHtml} />
    </section>

    <section>
      <h2 class="text-xl font-semibold mb-6">{tc.apiReference}</h2>
      <PropsTable title="Popover" props={popoverProps} />
      <PropsTable title="Popover.Trigger" props={triggerProps} />
      <PropsTable title="Popover.Content" props={contentProps} />
    </section>
  </div>
</DocsLayout>
