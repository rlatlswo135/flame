---
import '@fontsource-variable/geist';
import '@fontsource-variable/geist-mono';
import '../styles/globals.css';
import { ViewTransitions } from 'astro:transitions';
import { Toaster } from '@flame/ui';

interface Props {
  title?: string;
  locale: string;
}

const { title = 'Flame Design System', locale } = Astro.props;
---

<html lang={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content="A headless React component library for building accessible UIs" />
    <ViewTransitions />
    <script is:inline>
      function applyTheme() {
        const theme = document.cookie
          .split('; ')
          .find((row) => row.startsWith('flame-theme='))
          ?.split('=')[1];
        document.documentElement.classList.toggle('dark', theme === 'dark');
      }

      applyTheme(); // 최초 진입 (SSG 정적 HTML)
      document.addEventListener('astro:after-swap', applyTheme); // ViewTransitions 네비게이션
    </script>
  </head>
  <body class="antialiased min-h-screen bg-flame-bg text-flame-text">
    <slot />
    <Toaster client:load placement="bottom-right" className="flex flex-col gap-2 p-4" />
  </body>
</html>
