{
  "$schema": "https://biomejs.dev/schemas/2.4.6/schema.json",
  "extends": ["./configs/biome/biome.base.json"],
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "includes": [
      "**/*.{js,ts,jsx,tsx}",
      "!!**/node_modules",
      "!!**/dist",
      "!!**/.next",
      "!!**/build",
      "!!**/out",
      "!!**/next-env.d.ts"
    ]
  }
}
